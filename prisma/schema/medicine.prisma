model Medicine {
  id           String   @id @default(uuid())
  medicineName String   @db.VarChar(250)
  description  String   @db.Text
  price        Int
  imgUrl       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tags String[]
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])

  userId String
  isFeatured Boolean @default(false)
  status MEDICINESTATUS @default(PUBLISHED)
  views Int @default(0)
  review Review[]

  items OrderItem[]
  
  @@index([medicineName])
  @@map("medicines")
}

enum MEDICINESTATUS{
  ARCHIVED
  PUBLISHED
  DRAFT
}